rules_version = '2';

// WARNING: These rules are completely open and are for prototyping purposes only.
// They allow anyone to read, write, and delete any data in your database.
// Before deploying to production, you MUST replace these with secure rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
