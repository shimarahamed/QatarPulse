rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Safely access the role field, defaulting to 'user' if it doesn't exist.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    // This rule allows admins to perform collection group queries on 'reviews' for moderation purposes.
    match /{path=**}/reviews/{reviewId} {
      allow read: if isAdmin();
    }

    // Public content can be read by anyone.
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if request.auth.uid == resource.data.ownerId || isAdmin();
      allow delete: if isAdmin();

      // Reviews subcollection rules
      match /reviews/{reviewId} {
        // This rule handles non-admin reads for specific reviews.
        // It's combined with the collection group rule above. An admin read will be allowed by that rule.
        // Public can read approved reviews. Authors and business owners can read reviews related to them regardless of status.
        allow read: if resource.data.status == 'approved' 
                    || (request.auth != null && (request.auth.uid == resource.data.userId 
                    || (exists(/databases/$(database)/documents/businesses/$(businessId)) && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)));

        // Logged-in users can create their own review (as pending).
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
        
        // Admins can update status. Author can update their review. Owner can respond.
        allow update: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.userId || (exists(/databases/$(database)/documents/businesses/$(businessId)) && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid));
        
        // Users can delete their own review. Admins can delete any review.
        allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      }
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User-specific data
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /users/{userId}/lists/{listId} {
      allow read, write, delete: if request.auth.uid == userId;
    }

    // Claims can be created by any logged-in user.
    // Users can read their own claims.
    // Only admins can read all claims, update, or delete them.
    match /claims/{claimId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.claimerId);
      allow update, delete: if isAdmin();
    }
    
    // Submissions can be created by any logged-in user.
    // Only admins can read, or delete submissions.
    match /pending_businesses/{pendingBusinessId} {
      allow create: if request.auth != null;
      allow read, delete: if isAdmin();
    }

    // Ingestion sources and jobs are admin-only
    match /ingestion_sources/{sourceId} {
      allow read, write, delete: if isAdmin();
    }
    match /ingestion_jobs/{jobId} {
      allow read, write, delete: if isAdmin();
    }
  }
}
