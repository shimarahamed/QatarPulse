rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows admins to perform collection group queries on 'reviews' for moderation purposes.
    // It grants read access to the entire 'reviews' collection group for any user with the admin role.
    match /{path=**}/reviews/{reviewId} {
      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Public content can be read by anyone.
    match /businesses/{businessId} {
      allow read: if true;
      // Admins can create. Business owners or admins can update. Admins can delete.
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if request.auth.uid == resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Reviews subcollection rules
      match /reviews/{reviewId} {
        // This rule handles non-admin reads for specific reviews.
        // Public can read approved reviews. Authors and business owners can read reviews related to them regardless of status.
        allow read: if resource.data.status == 'approved' || (request.auth != null && (request.auth.uid == resource.data.userId || (exists(/databases/$(database)/documents/businesses/$(businessId)) && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid)));

        // Logged-in users can create their own review (as pending).
        allow create: if request.auth != null && request.auth.uid == reviewId && request.resource.data.status == 'pending' && request.resource.data.userId == request.auth.uid;
        
        // Admins can update status. Author can update their review. Owner can respond.
        allow update: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == reviewId || (exists(/databases/$(database)/documents/businesses/$(businessId)) && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid));
        
        // Users can delete their own review. Admins can delete any review.
        allow delete: if request.auth != null && (request.auth.uid == reviewId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }
    match /categories/{categoryId} {
      allow read: if true;
      // Admin only for writes
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /tags/{tagId} {
      allow read: if true;
      // Admin only for writes
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User-specific data
    match /users/{userId} {
      // Anyone can read user profiles to see display names, etc.
      allow read: if true;
      // Users can write their own profile. Admins can update any user's role.
      allow write: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId}/lists/{listId} {
      // Users can manage their own lists (e.g., favorites).
      allow read, write, delete: if request.auth.uid == userId;
    }

    // Claims can be created by any logged-in user.
    // Users can read their own claims.
    // Only admins can read all claims, update, or delete them.
    match /claims/{claimId} {
      allow create: if request.auth != null;
      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == resource.data.claimerId;
      allow update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Submissions can be created by any logged-in user.
    // Only admins can read, or delete submissions.
    match /pending_businesses/{pendingBusinessId} {
      allow create: if request.auth != null;
      allow read, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Ingestion sources and jobs are admin-only
    match /ingestion_sources/{sourceId} {
      allow read, write, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /ingestion_jobs/{jobId} {
      allow read, write, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
