rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public content can be read by anyone.
    match /businesses/{businessId} {
      allow read: if true;
      // Admins can create. Business owners or admins can update. Admins can delete.
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if request.auth.uid == resource.data.ownerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /categories/{categoryId} {
      allow read: if true;
      // Admin only for writes
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /tags/{tagId} {
      allow read: if true;
      // Admin only for writes
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User-specific data
    match /users/{userId} {
      // Anyone can read user profiles to see display names, etc.
      allow read: if true;
      // Users can write their own profile. Admins can update any user's role.
      allow write: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId}/lists/{listId} {
      // Users can manage their own lists (e.g., favorites).
      allow read, write, delete: if request.auth.uid == userId;
    }

    // Claims can be created by any logged-in user.
    // Users can read their own claims.
    // Only admins can read all claims, update, or delete them.
    match /claims/{claimId} {
      allow create: if request.auth != null;
      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == resource.data.claimerId;
      allow update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Submissions can be created by any logged-in user.
    // Only admins can read, or delete submissions.
    match /pending_businesses/{pendingBusinessId} {
      allow create: if request.auth != null;
      allow read, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
