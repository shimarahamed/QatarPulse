{
  "entities": {
    "Business": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Business",
      "type": "object",
      "description": "Comprehensive details for a business listing, serving as the core entity for the directory platform.",
      "properties": {
        "slug": { "type": "string", "description": "URL-friendly unique identifier."},
        "name_en": { "type": "string", "description": "The English name of the business." },
        "name_ar": { "type": "string", "description": "The Arabic name of the business." },
        "description_en": { "type": "string", "description": "A detailed English description of the business." },
        "description_ar": { "type": "string", "description": "A detailed Arabic description of the business." },
        "category_id": { "type": "string", "description": "Reference to the Category this business belongs to." },
        "tag_ids": { "type": "array", "items": { "type": "string" }, "description": "References to Tags/Services associated with this business." },
        "address_en": { "type": "string", "description": "The English street address." },
        "address_ar": { "type": "string", "description": "The Arabic street address." },
        "geo": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "phone": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "opening_hours": { "type": "object" },
        "price_range": { "type": "string" },
        "verified_status": { "type": "boolean", "default": false },
        "status": { "type": "string", "default": "active" },
        "rating": { "type": "number" },
        "review_count": { "type": "number" },
        "logo_id": { "type": "string" },
        "image_ids": { "type": "array", "items": { "type": "string" } },
        "ownerId": { "type": "string", "description": "Reference to the UserProfile ID of the business owner." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name_en", "category_id", "status", "createdAt", "updatedAt"]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Defines a classification category for businesses.",
      "properties": {
        "name_en": { "type": "string" },
        "name_ar": { "type": "string" },
        "icon_name": { "type": "string", "description": "Name of the lucide-react icon." }
      },
      "required": ["name_en", "name_ar", "icon_name"]
    },
    "Tag": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tag",
      "type": "object",
      "description": "Represents a searchable tag or service.",
      "properties": {
        "name_en": { "type": "string" },
        "name_ar": { "type": "string" }
      },
      "required": ["name_en", "name_ar"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores application-specific profile data for users.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["user", "admin", "business-owner"], "default": "user" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "UserList": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "UserList",
        "type": "object",
        "description": "A user's list of businesses, like favorites.",
        "properties": {
            "name": { "type": "string" },
            "businessIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name", "businessIds"]
    },
    "BusinessClaim": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "BusinessClaim",
        "type": "object",
        "description": "A claim for business ownership.",
        "properties": {
            "businessId": { "type": "string" },
            "businessName": { "type": "string" },
            "claimerName": { "type": "string" },
            "claimerEmail": { "type": "string" },
            "claimerPhone": { "type": "string" },
            "claimerId": { "type": "string" },
            "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "default": "pending" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["businessId", "businessName", "claimerId", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "/businesses/{businessId}": {
        "schema": { "$ref": "#/entities/Business" },
        "description": "Main collection for business listings."
    },
    "/categories/{categoryId}": {
        "schema": { "$ref": "#/entities/Category" },
        "description": "Global lookup collection for business categories."
    },
    "/tags/{tagId}": {
        "schema": { "$ref": "#/entities/Tag" },
        "description": "Global lookup collection for searchable tags/services."
    },
    "/users/{userId}": {
        "schema": { "$ref": "#/entities/UserProfile" },
        "description": "Stores application-specific user profiles."
    },
    "/users/{userId}/lists/{listId}": {
        "schema": { "$ref": "#/entities/UserList" },
        "description": "Subcollection for user-specific lists of businesses."
    },
    "/claims/{claimId}": {
        "schema": { "$ref": "#/entities/BusinessClaim" },
        "description": "Manages business claim requests."
    }
  }
}
